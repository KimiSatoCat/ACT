# ───────────────────────────────────────────────────────────────
# ACT App — 環境変数テンプレート
#
# 使い方:
#   cp .env.example .env.local
#   .env.local に実際の値を入力する（.gitignore に追加済み）
#
# Expo では EXPO_PUBLIC_ プレフィックスが付いた変数のみクライアントに公開される。
# シークレット（秘密鍵等）は Cloud Functions の環境変数として設定し、
# クライアントには決して露出させないこと。
# ───────────────────────────────────────────────────────────────

# ── Firebase ─────────────────────────────────────────────────
# Firebase Console → プロジェクト設定 → マイアプリ → SDK の設定と構成 で確認
EXPO_PUBLIC_FIREBASE_API_KEY=your_api_key_here
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=act-e4a47.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=act-e4a47
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=act-e4a47.firebasestorage.app
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
EXPO_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:0000000000000000

# ── Cloud Functions ───────────────────────────────────────────
# デプロイ後: https://asia-northeast1-act-e4a47.cloudfunctions.net
# エミュレーター: http://localhost:5001/act-e4a47/asia-northeast1
EXPO_PUBLIC_FUNCTIONS_BASE_URL=https://asia-northeast1-act-e4a47.cloudfunctions.net

# ── Claude API (Cloud Functions 側のみ — クライアントには公開しない) ─
# Cloud Functions デプロイ時に設定:
#   firebase functions:secrets:set ANTHROPIC_API_KEY
# ANTHROPIC_API_KEY=sk-ant-...
