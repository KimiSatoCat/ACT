# ───────────────────────────────────────────────────────────────
# ACT App — 環境変数テンプレート
#
# 使い方:
#   cp .env.example .env.local
#   .env.local に実際の値を入力する（.gitignore に追加済み）
#
# Expo では EXPO_PUBLIC_ プレフィックスが付いた変数のみクライアントに公開される。
# シークレット（秘密鍵等）は Cloud Functions の環境変数として設定し、
# クライアントには決して露出させないこと。
# ───────────────────────────────────────────────────────────────

# ── Firebase ─────────────────────────────────────────────────
EXPO_PUBLIC_FIREBASE_API_KEY=your_api_key_here
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
EXPO_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:0000000000000000

# ── Cloud Functions ───────────────────────────────────────────
# 本番: https://asia-northeast1-your_project_id.cloudfunctions.net
# エミュレーター: http://localhost:5001/your_project_id/asia-northeast1
EXPO_PUBLIC_FUNCTIONS_BASE_URL=https://asia-northeast1-your_project_id.cloudfunctions.net

# ── Claude API (Cloud Functions 側で使用 — クライアントには公開しない) ─
# ANTHROPIC_API_KEY=sk-ant-...  ← Cloud Functions の Secret Manager に設定
