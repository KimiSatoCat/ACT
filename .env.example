# ───────────────────────────────────────────────────────────────
# ACT App — 環境変数テンプレート
#
# 使い方:
#   1. このファイルをコピーして .env.local を作る
#      Windows: copy .env.example .env.local
#   2. .env.local に実際の値を入力する（.gitignore に追加済み）
# ───────────────────────────────────────────────────────────────

# ── Firebase（Firebase Console → プロジェクト設定 → マイアプリ）──────────
EXPO_PUBLIC_FIREBASE_API_KEY=your_api_key_here
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=act-e4a47.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=act-e4a47
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=act-e4a47.firebasestorage.app
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
EXPO_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:0000000000000000

# ── Google Sign-In（Firebase Console → Authentication → Google → ウェブクライアントID）──
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=000000000000-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
# Android / iOS のネイティブビルドを使う場合のみ設定（Expo Go では不要）
# EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
# EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=

# ── Anthropic Claude API（https://console.anthropic.com/settings/keys）──
# ※ このキーはアプリバンドルに含まれます。個人利用・研究目的の場合に限り使用してください。
EXPO_PUBLIC_ANTHROPIC_API_KEY=sk-ant-...
